# Copy to .byedroid.toml in your Android project root.
# Legacy .loopcat.toml and .droid-loop.toml files are still read if present.
# If omitted, byedroid infers application IDs and default assemble/install tasks from app/build.gradle(.kts).

# Single package (optional if Gradle lists applicationId)
# package = "com.example.app"

# Or set explicit app IDs (overrides inference), e.g. multiple flavors:
# packages = ["ai.wayve.app", "ai.wayve.app.dev"]

variant = "debug"

# Optional — inferred as assemble<Flavor>Debug / install<Flavor>Debug when possible
# assemble_task = "assembleDevDebug"
# install_task  = "installDevDebug"

# Optional: comma-separated levels in log_level for filtering (see modules/logcat.rs)
log_level = "D,I,W,E,V"

# Tag substrings — line must match at least one if non-empty
log_filters = ["OkHttp"]

# Lines containing any of these substrings are dropped (noisy tags, etc.)
exclude_filters = ["chatty", "ViewRootImpl"]

# Extra arguments passed to `scrcpy`
scrcpy_args = ["--window-title", "ByeDroid"]
